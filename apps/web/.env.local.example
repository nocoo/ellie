# Ellie Web (Forum Frontend) — local environment
#
# Copy to apps/web/.env.local and fill in real values.
#   cp apps/web/.env.local.example apps/web/.env.local
#
# .env.local is gitignored (see /.gitignore). Never commit real secrets.
#
# Port convention: web dev server runs on 7031 (see apps/web/package.json).

# ─── Required ─────────────────────────────────────────────────────────────

# NextAuth v5 JWT signing secret. Rotating this invalidates every
# existing session. Generate: `openssl rand -base64 32`.
AUTH_SECRET=

# Origin the web app is served on. Used for CSRF Origin whitelist
# (lib/csrf.ts) and secure-cookie detection (lib/forum-auth.ts).
# Local dev: http://localhost:7031
AUTH_URL=http://localhost:7031

# URL of the Cloudflare Worker. `wrangler dev` defaults to 8787.
WORKER_API_URL=http://127.0.0.1:8787

# Forum API key. MUST match the worker's API_KEY secret in /.dev.vars.
# Server-side only — never exposed to the browser bundle.
FORUM_API_KEY=

# Public site URL — added to the CSRF Origin whitelist alongside AUTH_URL.
# Local dev: same as AUTH_URL. Production: the customer-facing domain.
NEXT_PUBLIC_SITE_URL=http://localhost:7031

# Cap CAPTCHA endpoint (fronts login / register / email-verify /
# report submission). When empty the flows render fail-closed with
# "邮箱验证暂不可用" (see viewmodels/forum/email-verification.ts).
# Local dev tip: leave blank if you're not testing those flows.
NEXT_PUBLIC_CAP_API_ENDPOINT=

# ─── Optional ─────────────────────────────────────────────────────────────

# Shared secret for the P5 analytics ingest bridge. MUST match the
# worker's ANALYTICS_INGEST_KEY. When unset the web proxy silently
# drops page-view samples (ingest is opportunistic and never blocks
# navigation).
ANALYTICS_INGEST_KEY=
