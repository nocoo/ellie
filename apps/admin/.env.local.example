# Ellie Admin (Admin Console) — local environment
#
# Copy to apps/admin/.env.local and fill in real values.
#   cp apps/admin/.env.local.example apps/admin/.env.local
#
# .env.local is gitignored (see /.gitignore). Never commit real secrets.
#
# Port convention: admin dev server runs on 7032 (see apps/admin/package.json).

# ─── Required ─────────────────────────────────────────────────────────────

# NextAuth v5 JWT signing secret. Kept independent from the web app's
# AUTH_SECRET on purpose so a leak of one never grants the other's scope.
# Generate: `openssl rand -base64 32`.
AUTH_SECRET=

# Origin the admin app is served on. Used for CSRF Origin whitelist
# (lib/csrf.ts). Local dev: http://localhost:7032
AUTH_URL=http://localhost:7032

# Google OAuth credentials. Admin login is Google-only (Cloudflare
# Access is stripped in dev), so both fields are required for any
# admin login flow to work locally. Register a "Web application" OAuth
# client at https://console.cloud.google.com/apis/credentials and add
# ${AUTH_URL}/api/auth/callback/google to the authorized redirect URIs.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Comma-separated allowlist of Google account emails permitted to
# access the admin console. A user whose Google email is not in this
# list will pass Google OAuth and then be rejected by lib/admin.ts
# with "非管理员账号". Match on lowercase; whitespace is trimmed.
#   e.g. ADMIN_EMAILS=you@example.com,ops@example.com
ADMIN_EMAILS=

# URL of the Cloudflare Worker. Same as web — `wrangler dev` port 8787.
WORKER_API_URL=http://127.0.0.1:8787

# Admin API key. MUST match the worker's ADMIN_API_KEY secret in
# /.dev.vars. Server-side only — never exposed to the browser bundle.
# This is Key B (admin scope), distinct from the forum's FORUM_API_KEY
# (Key A).
ADMIN_API_KEY=
