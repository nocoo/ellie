#!/bin/bash
# Pre-commit hook — parallel quality gates.
# Husky runs hooks via "sh -e"; re-exec under bash for associative syntax.
if [ -z "$_ELLIE_HOOK_BASH" ]; then export _ELLIE_HOOK_BASH=1; exec bash "$0" "$@"; fi

# Stages: lint-staged + L1 coverage + L2 + gitleaks + typecheck + rust (conditional)
#
# Semantically a parallel realization of `bun run gate:g1` (typecheck + lint
# via lint-staged + L1 coverage) plus L2 + the staged-only gitleaks scan that
# pre-commit needs. Pre-push covers the full repo gitleaks + osv-scanner.
# When changing the gate definition update both .husky/pre-commit/pre-push
# and the gate:* scripts in package.json so semantics stay in lockstep.

set -o pipefail

TMPDIR_HOOK=$(mktemp -d -t ellie-precommit-XXXXXX)
trap 'rm -rf "$TMPDIR_HOOK"' EXIT

# Detect what files are staged
HAS_TS=$(git diff --cached --name-only | grep -E '\.(ts|tsx)$' | head -1)
HAS_RUST=$(git diff --cached --name-only | grep -E '\.rs$|packages/cli-rs/Cargo\.(toml|lock)' | head -1)

run_bg() {
  local name="$1"; shift
  ( "$@" >"$TMPDIR_HOOK/$name.log" 2>&1; echo $? >"$TMPDIR_HOOK/$name.exit" ) &
  eval "PID_$name=$!"
}

wait_stage() {
  local name="$1" pid_var="PID_$1" pid status
  pid=${!pid_var}
  wait "$pid" 2>/dev/null || true
  status=$(cat "$TMPDIR_HOOK/$name.exit" 2>/dev/null || echo 1)
  echo "━━━ $name (exit=$status) ━━━"
  cat "$TMPDIR_HOOK/$name.log"
  if [ "$status" -ne 0 ]; then
    echo "❌ pre-commit stage '$name' failed" >&2
    exit "$status"
  fi
}

# Launch parallel stages
run_bg lint       bunx lint-staged
run_bg unit       bun run test:coverage
run_bg gitleaks   gitleaks protect --staged --no-banner
run_bg l2         bun run test:l2

if [ -n "$HAS_TS" ]; then
  run_bg typecheck  bun run typecheck
fi

# Rust checks (conditional)
if [ -n "$HAS_RUST" ] && [ -f "packages/cli-rs/Cargo.toml" ]; then
  run_bg rust bash -c 'cd packages/cli-rs && cargo fmt --check --all && cargo clippy --all-targets --all-features -- -D warnings && cargo test --workspace'
fi

# Wait in order — fail fast on first failure
wait_stage lint
wait_stage unit
wait_stage gitleaks
wait_stage l2
if [ -n "$HAS_TS" ]; then
  wait_stage typecheck
fi
if [ -n "$HAS_RUST" ] && [ -f "packages/cli-rs/Cargo.toml" ]; then
  wait_stage rust
fi
