# L1 + G1 + G2 — full gate check before push
bun run typecheck                              # G1: compile check
bun test tests/unit/                           # L1: web unit tests
bun test apps/worker                           # L1: worker unit tests

# L2: Worker integration tests (auto-start worker if needed)
echo "[pre-push] Starting L2 integration tests..."
WORKER_PID=""
if ! curl -sf http://localhost:8787/api/live > /dev/null 2>&1; then
  echo "[pre-push] Starting test Worker on port 8787..."
  npx wrangler dev -c apps/worker/wrangler.toml --env test --remote --port 8787 > /dev/null 2>&1 &
  WORKER_PID=$!
  # Wait for worker to be ready (max 30s)
  for i in $(seq 1 60); do
    if curl -sf http://localhost:8787/api/live > /dev/null 2>&1; then
      echo "[pre-push] Worker ready"
      break
    fi
    sleep 0.5
  done
  if ! curl -sf http://localhost:8787/api/live > /dev/null 2>&1; then
    echo "[pre-push] ERROR: Worker failed to start"
    [ -n "$WORKER_PID" ] && kill $WORKER_PID 2>/dev/null
    exit 1
  fi
fi
bun test --preload ./tests/integration/preload.ts tests/integration/worker/
L2_EXIT=$?
[ -n "$WORKER_PID" ] && kill $WORKER_PID 2>/dev/null
if [ $L2_EXIT -ne 0 ]; then
  echo "[pre-push] L2 tests failed"
  exit 1
fi

osv-scanner scan --lockfile bun.lock           # G2: dependency vulnerability scan
gitleaks detect --no-banner                    # G2: secret leak detection

# Rust L2 + G2 (if cli-rs exists)
if [ -f "packages/cli-rs/Cargo.toml" ]; then
  cd packages/cli-rs
  if [ -n "$ELLIE_API_URL" ] && [ -n "$ELLIE_API_KEY" ]; then
    cargo test --test integration -- --ignored   # L2 (requires test Worker env vars)
  else
    echo "Skipping Rust L2: ELLIE_API_URL/ELLIE_API_KEY not set"
  fi
  osv-scanner scan --lockfile Cargo.lock       # G2
  cd ../..
fi
