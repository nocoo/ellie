# Ellie — Environment Variables
# Copy to .env.local and adjust values as needed.

# NextAuth v5 JWT signing secret (required)
# Generate a real secret for production: openssl rand -base64 32
AUTH_SECRET=ellie-dev-secret-not-for-production

# P5 analytics ingest — shared secret used by the Next.js web proxy to
# authenticate against the Worker's /api/internal/analytics/ingest
# endpoint.
#
# SECURITY (D0 v2):
#   - Server-only. MUST NOT be prefixed `NEXT_PUBLIC_*` and MUST NOT be
#     read in any client component / browser bundle.
#   - The matching secret on the Worker side lives as a Cloudflare
#     secret (`wrangler secret put ANALYTICS_INGEST_KEY`) — NOT in any
#     `.dev.vars.example`. Both sides MUST hold the same value at
#     runtime.
#   - If unset, the web proxy silently drops ingest samples (ingest is
#     opportunistic and MUST NOT block navigation), and the Worker
#     handler returns 503 INGEST_NOT_CONFIGURED.
# Generate a real secret for production: openssl rand -base64 32
ANALYTICS_INGEST_KEY=
