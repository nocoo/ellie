# Ellie — Environment Variables
#
# There is NO single .env at the repo root — Ellie is a monorepo and
# each app owns its own environment file. Copy the three examples
# below to their real names and fill in values.
#
#   apps/worker/.dev.vars.example     → /.dev.vars
#                                       (apps/worker/.dev.vars must be
#                                        a symlink → ../../.dev.vars)
#   apps/web/.env.local.example       → apps/web/.env.local
#   apps/admin/.env.local.example     → apps/admin/.env.local
#
# See CLAUDE.md > Secrets & Environment for the routing rules
# (Key A vs Key B, which client hits which side).
#
# Generate secrets: `openssl rand -base64 32`
#
# ─── Legacy fields (kept for backwards compat) ───────────────────────────
#
# The two fields below were the only ones tracked before the per-app
# examples above existed. They still work if you keep them here, but
# the per-app files are now the source of truth.

# NextAuth v5 JWT signing secret (used by both web and admin — each
# app should have its own value in its own .env.local).
AUTH_SECRET=

# P5 analytics ingest — shared secret used by the Next.js web proxy to
# authenticate against the Worker's /api/internal/analytics/ingest
# endpoint.
#
# SECURITY (D0 v2):
#   - Server-only. MUST NOT be prefixed `NEXT_PUBLIC_*` and MUST NOT be
#     read in any client component / browser bundle.
#   - The matching secret on the Worker side lives as a Cloudflare
#     secret (`wrangler secret put ANALYTICS_INGEST_KEY`) — NOT in any
#     `.dev.vars.example`. Both sides MUST hold the same value at
#     runtime.
#   - If unset, the web proxy silently drops ingest samples (ingest is
#     opportunistic and MUST NOT block navigation), and the Worker
#     handler returns 503 INGEST_NOT_CONFIGURED.
ANALYTICS_INGEST_KEY=
