{
	"name": "ellie-monorepo",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "pnpm --filter web dev",
		"build": "pnpm --filter web build",
		"start": "pnpm --filter web start",
		"migrate": "pnpm --filter migrate start",
		"cli": "pnpm --filter cli start",
		"worker:dev": "pnpm --filter worker dev",
		"worker:deploy": "pnpm --filter worker deploy",
		"tui": "bun --bun run scripts/tui.ts",
		"test": "pnpm -r test",
		"test:unit": "pnpm -r --filter '!**/e2e' run test:unit",
		"test:integration": "pnpm -r run test:integration",
		"test:e2e": "pnpm --filter web run test:e2e",
		"typecheck": "pnpm -r exec tsc --noEmit",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"prepare": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"@emoji-mart/data": "^1.2.1",
		"@emoji-mart/react": "^1.1.1",
		"@playwright/test": "^1.58.2",
		"@tiptap/extension-character-count": "^3.21.0",
		"@tiptap/extension-link": "^3.21.0",
		"@tiptap/extension-placeholder": "^3.21.0",
		"@tiptap/react": "^3.21.0",
		"@tiptap/starter-kit": "^3.21.0",
		"@types/bun": "^1.2.0",
		"@types/node": "^22",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"typescript": "^5.9"
	},
	"trustedDependencies": ["@biomejs/biome"],
	"engines": {
		"node": ">=22",
		"pnpm": ">=9"
	},
	"lint-staged": {
		"*.{ts,tsx,js,jsx,json,css,md}": ["biome check --no-errors-on-unmatched"]
	}
}
