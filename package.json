{
	"name": "ellie-monorepo",
	"version": "1.1.0",
	"private": true,
	"type": "module",
	"workspaces": ["apps/*", "packages/*"],
	"scripts": {
		"dev": "bun run dev:forum",
		"dev:forum": "bun run --filter web dev",
		"dev:admin": "bun run --filter admin dev",
		"dev:all": "bun run --filter web --filter admin dev",
		"build": "bun run --filter web --filter admin build",
		"build:forum": "bun run --filter web build",
		"build:admin": "bun run --filter admin build",
		"start": "bun run --filter web start",
		"start:forum": "bun run --filter web start",
		"start:admin": "bun run --filter admin start",
		"migrate": "bun run --filter migrate start",
		"cli": "bun run --filter cli start",
		"worker:dev": "bun run --filter '@ellie/worker' dev",
		"worker:deploy": "bun run --filter '@ellie/worker' deploy",
		"worker:deploy:test": "wrangler deploy -c apps/worker/wrangler.toml --env test",
		"tui": "bun --bun run scripts/tui.ts",
		"release": "bun run scripts/release.ts",
		"test": "vitest run && bun test tests/unit/auth-callbacks.test.ts tests/unit/loader.test.ts tests/unit/verify.test.ts tests/unit/proxy.test.ts tests/unit/hooks/use-is-mobile.test.ts tests/unit/hooks/use-theme.test.ts",
		"test:unit": "vitest run",
		"test:unit:bun": "bun test tests/unit/auth-callbacks.test.ts tests/unit/loader.test.ts tests/unit/verify.test.ts tests/unit/proxy.test.ts tests/unit/hooks/use-is-mobile.test.ts tests/unit/hooks/use-theme.test.ts",
		"test:worker": "vitest run --project worker",
		"test:web": "vitest run --project web",
		"test:admin": "vitest run --project admin",
		"test:shared": "vitest run --project shared",
		"test:test-mocks": "vitest run --project test-mocks",
		"test:coverage": "vitest run -c apps/worker/vitest.config.ts --coverage && vitest run -c apps/web/vitest.config.ts --coverage && vitest run -c apps/admin/vitest.config.ts --coverage && vitest run -c packages/shared/vitest.config.ts --coverage && vitest run -c packages/test-mocks/vitest.config.ts --coverage",
		"test:coverage:worker": "vitest run -c apps/worker/vitest.config.ts --coverage",
		"test:coverage:web": "vitest run -c apps/web/vitest.config.ts --coverage",
		"test:coverage:admin": "vitest run -c apps/admin/vitest.config.ts --coverage",
		"test:coverage:shared": "vitest run -c packages/shared/vitest.config.ts --coverage",
		"test:coverage:test-mocks": "vitest run -c packages/test-mocks/vitest.config.ts --coverage",
		"test:integration": "bun test --preload ./tests/integration/preload.ts tests/integration/",
		"test:integration:worker": "bun test --preload ./tests/integration/preload.ts tests/integration/worker/",
		"test:integration:proxy": "bun test tests/integration/proxy/",
		"test:l2": "bun run scripts/run-l2.ts",
		"test:e2e:api": "bun run scripts/run-l2.ts",
		"verify:test-db": "bun run scripts/verify-test-db.ts",
		"test:e2e": "bunx playwright test -c playwright.config.ts",
		"test:e2e:browser": "bun run scripts/run-l3.ts",
		"typecheck": "tsc --build",
		"lint": "biome check --error-on-warnings .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"prepare": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"@ellie/test-mocks": "workspace:*",
		"@ellie/types": "workspace:*",
		"@emoji-mart/data": "^1.2.1",
		"@emoji-mart/react": "^1.1.1",
		"@playwright/test": "^1.58.2",
		"@tiptap/extension-character-count": "^3.21.0",
		"@tiptap/extension-link": "^3.21.0",
		"@tiptap/extension-placeholder": "^3.21.0",
		"@tiptap/react": "^3.21.0",
		"@tiptap/starter-kit": "^3.21.0",
		"@types/bun": "^1.2.0",
		"@types/node": "^22",
		"@vitest/coverage-v8": "^4.1.5",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"typescript": "^5.9",
		"vitest": "^4.1.5"
	},
	"trustedDependencies": ["@biomejs/biome"],
	"packageManager": "bun@1.3.11",
	"engines": {
		"node": ">=22",
		"bun": ">=1.0"
	},
	"lint-staged": {
		"*.{ts,tsx,js,jsx,json,css,md}": ["biome check --error-on-warnings --no-errors-on-unmatched"]
	},
	"dependencies": {
		"defu": "^6.1.6",
		"dompurify": "^3.4.0",
		"hono": "^4.12.14"
	},
	"overrides": {
		"dompurify": "^3.4.0",
		"hono": "^4.12.14",
		"postcss": "^8.5.10"
	}
}
