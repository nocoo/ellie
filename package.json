{
	"name": "ellie-monorepo",
	"version": "1.6.7",
	"private": true,
	"type": "module",
	"workspaces": ["apps/*", "packages/*"],
	"scripts": {
		"dev": "bun run dev:forum",
		"dev:forum": "bun run --filter web dev",
		"dev:admin": "bun run --filter admin dev",
		"dev:all": "bun run --filter web --filter admin dev",
		"build": "bun run --filter web --filter admin build",
		"build:forum": "bun run --filter web build",
		"build:admin": "bun run --filter admin build",
		"start": "bun run --filter web start",
		"start:forum": "bun run --filter web start",
		"start:admin": "bun run --filter admin start",
		"migrate": "bun run --filter migrate start",
		"cli": "bun run --filter cli start",
		"worker:dev": "bun run --filter '@ellie/worker' dev",
		"worker:migrate:prod": "cd apps/worker && bun x wrangler d1 migrations apply tongjinet-db --remote",
		"worker:migrate:test": "cd apps/worker && bun x wrangler d1 migrations apply tongjinet-db-test --remote --env test",
		"worker:deploy": "bun run worker:migrate:prod && bun run --filter '@ellie/worker' deploy",
		"worker:deploy:test": "bun run worker:migrate:test && wrangler deploy -c apps/worker/wrangler.toml --env test",
		"tui": "bun --bun run scripts/tui.ts",
		"release": "bun run scripts/release.ts",
		"test": "bash scripts/run-tests.sh",
		"test:unit": "vitest run --experimental.fsModuleCache",
		"test:unit:bun": "bun test \"$PWD/tests/unit/loader.test.ts\" \"$PWD/tests/unit/verify.test.ts\"",
		"test:worker": "vitest run --experimental.fsModuleCache -c apps/worker/vitest.config.ts",
		"test:web": "vitest run --experimental.fsModuleCache -c apps/web/vitest.config.ts",
		"test:admin": "vitest run --experimental.fsModuleCache -c apps/admin/vitest.config.ts",
		"test:shared": "vitest run --experimental.fsModuleCache -c packages/shared/vitest.config.ts",
		"test:test-mocks": "vitest run --experimental.fsModuleCache -c packages/test-mocks/vitest.config.ts",
		"test:types": "vitest run --experimental.fsModuleCache -c packages/types/vitest.config.ts",
		"test:migrate": "vitest run --experimental.fsModuleCache -c packages/migrate/vitest.config.ts",
		"test:coverage": "vitest run -c apps/worker/vitest.config.ts --coverage && vitest run -c apps/web/vitest.config.ts --coverage && vitest run -c apps/admin/vitest.config.ts --coverage && vitest run -c packages/shared/vitest.config.ts --coverage && vitest run -c packages/test-mocks/vitest.config.ts --coverage && vitest run -c packages/types/vitest.config.ts --coverage && vitest run -c packages/migrate/vitest.config.ts --coverage",
		"test:coverage:worker": "vitest run -c apps/worker/vitest.config.ts --coverage",
		"test:coverage:web": "vitest run -c apps/web/vitest.config.ts --coverage",
		"test:coverage:admin": "vitest run -c apps/admin/vitest.config.ts --coverage",
		"test:coverage:shared": "vitest run -c packages/shared/vitest.config.ts --coverage",
		"test:coverage:test-mocks": "vitest run -c packages/test-mocks/vitest.config.ts --coverage",
		"test:coverage:types": "vitest run -c packages/types/vitest.config.ts --coverage",
		"test:coverage:migrate": "vitest run -c packages/migrate/vitest.config.ts --coverage",
		"test:integration": "bun test --preload ./tests/integration/preload.ts tests/integration/",
		"test:integration:worker": "bun test --preload ./tests/integration/preload.ts tests/integration/worker/",
		"test:integration:proxy": "bun test tests/integration/proxy/",
		"test:l2": "bun run scripts/run-l2.ts",
		"test:e2e:api": "bun run scripts/run-l2.ts",
		"verify:test-db": "bun run scripts/verify-test-db.ts",
		"test:e2e": "bunx playwright test -c playwright.config.ts",
		"test:e2e:browser": "bun run scripts/run-l3.ts",
		"test:e2e:admin": "bun run scripts/run-l3-admin.ts",
		"typecheck": "bash scripts/typecheck.sh",
		"lint": "biome check --error-on-warnings .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"gate:g1": "bun run typecheck && bun run lint && bun run test:coverage",
		"gate:g2": "gitleaks detect --no-banner && osv-scanner scan --lockfile bun.lock",
		"gate:l2": "bun run test:l2 && bun run scripts/audit-l2-coverage.ts --strict-coverage",
		"gate:full": "bun run gate:g1 && bun run gate:l2 && bun run gate:g2",
		"prepare": "husky"
	},
	"devDependencies": {
		"@auth/core": "0.41.0",
		"@biomejs/biome": "^1.9.0",
		"@ellie/test-mocks": "workspace:*",
		"@ellie/types": "workspace:*",
		"@emoji-mart/data": "^1.2.1",
		"@emoji-mart/react": "^1.1.1",
		"@playwright/test": "^1.60.0",
		"@tiptap/extension-character-count": "^3.23.6",
		"@tiptap/extension-image": "3.23.6",
		"@tiptap/extension-link": "^3.23.6",
		"@tiptap/extension-placeholder": "^3.23.6",
		"@tiptap/extension-underline": "3.23.6",
		"@tiptap/react": "^3.23.6",
		"@tiptap/starter-kit": "^3.23.6",
		"@types/bun": "^1.3.14",
		"@types/node": "^25",
		"@vitest/coverage-v8": "^4.1.7",
		"happy-dom": "^20.9.0",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.5",
		"typescript": "^5.9",
		"vitest": "^4.1.7"
	},
	"trustedDependencies": ["@biomejs/biome"],
	"packageManager": "bun@1.3.14",
	"engines": {
		"node": ">=22",
		"bun": ">=1.0"
	},
	"lint-staged": {
		"*.{ts,tsx,js,jsx,json,css,md}": ["biome check --error-on-warnings --no-errors-on-unmatched"]
	},
	"dependencies": {
		"@base-ui/react": "^1.5.0",
		"@cap.js/widget": "^0.1.53",
		"@cloudflare/workers-types": "^4.20260525.1",
		"@radix-ui/react-avatar": "^1.1.11",
		"@radix-ui/react-checkbox": "^1.3.3",
		"@radix-ui/react-collapsible": "^1.1.12",
		"@radix-ui/react-dialog": "^1.1.15",
		"@radix-ui/react-dropdown-menu": "^2.1.16",
		"@radix-ui/react-label": "^2.1.8",
		"@radix-ui/react-popover": "^1.1.15",
		"@radix-ui/react-select": "^2.2.6",
		"@radix-ui/react-separator": "^1.1.8",
		"@radix-ui/react-slot": "^1.2.4",
		"@radix-ui/react-tabs": "^1.1.13",
		"@radix-ui/react-tooltip": "^1.2.8",
		"dompurify": "^3.4.5",
		"fast-uri": "^3.1.2",
		"hono": "^4.12.23",
		"lucide-react": "^1.16.0",
		"tailwind-merge": "^3.6.0"
	},
	"overrides": {
		"brace-expansion": "^5.0.6",
		"cookie": "^0.7.2",
		"defu": "^6.1.7",
		"dompurify": "^3.4.5",
		"esbuild": "^0.25.0",
		"fast-uri": "^3.1.2",
		"hono": "^4.12.22",
		"ip-address": "^10.1.1",
		"postcss": "^8.5.10",
		"undici": "^6.23.0",
		"ws": "^8.20.1"
	}
}
