{
	"name": "ellie",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "next dev --turbopack",
		"build": "next build",
		"start": "next start",
		"migrate": "bun run scripts/migrate/index.ts",
		"test": "bun test",
		"test:unit": "bun test tests/unit/",
		"test:integration": "bun test --preload ./tests/integration/preload.ts tests/integration/",
		"test:coverage": "bun test --coverage tests/unit/",
		"test:e2e": "bunx playwright test",
		"typecheck": "tsc --noEmit",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"prepare": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"@playwright/test": "^1.58.2",
		"@types/bun": "^1.2.0",
		"@types/node": "^22",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0",
		"typescript": "^5.9"
	},
	"trustedDependencies": ["@biomejs/biome"],
	"dependencies": {
		"@auth/core": "^0.34.3",
		"@base-ui/react": "^1.3.0",
		"@tailwindcss/postcss": "^4",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"lucide-react": "^1.7.0",
		"next": "^16",
		"next-auth": "^5.0.0-beta.30",
		"react": "^19",
		"react-dom": "^19",
		"shadcn": "^4.1.0",
		"tailwind-merge": "^3.5.0",
		"tailwindcss": "^4",
		"tw-animate-css": "^1.4.0"
	},
	"lint-staged": {
		"*.{ts,tsx,js,jsx,json,css,md}": ["biome check --no-errors-on-unmatched"]
	}
}
