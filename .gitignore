# Reference data (local only, not committed)
reference/

# Dependencies
node_modules/

# Build output
dist/
.next/
*.tsbuildinfo
coverage/

# Test artifacts
test-results/
playwright-report/

# TypeScript build output for packages/db and packages/migrate
packages/db/src/*.js
packages/db/src/*.d.ts
packages/migrate/src/*.js
packages/migrate/src/*.d.ts
packages/migrate/src/**/*.js
packages/migrate/src/**/*.d.ts

# Bun
bun.lockb

# Migration output
output/
*.db
*.sqlite
*.sqlite-shm
*.sqlite-wal

# Logs
*.log

# Environment
.env
.env.local
.env.test
apps/web/.env.test
.dev.vars

# Next.js generated
next-env.d.ts

# Rust
target/
*.so
*.dylib
*.dll

# Wrangler
.wrangler/

# OS junk
.DS_Store
*.swp
*.swo

# Tools
.claude/
.superset/
# Data import files (may contain real user data)
scripts/*-import.sql
scripts/*-data.sql
**/import-*.sql
.autoresearch/
tests/e2e/.auth/

# Wrangler config (contains resource IDs — use wrangler.toml.example)
apps/worker/wrangler.toml

# Migration state (contains real DB IDs)
packages/migrate/production-state.json
