{
	"$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
	"assist": { "actions": { "source": { "organizeImports": "on" } } },
	"linter": {
		"enabled": true,
		"rules": {
			"preset": "recommended",
			"a11y": {
				"noStaticElementInteractions": "off",
				"useAriaPropsSupportedByRole": "off"
			},
			"complexity": {
				"noExcessiveCognitiveComplexity": {
					"level": "warn",
					"options": {
						"maxAllowedComplexity": 25
					}
				},
				"useOptionalChain": "off",
				"noImportantStyles": "off"
			},
			"correctness": {
				"noUnusedVariables": "error",
				"noUnusedImports": "error",
				"useParseIntRadix": "off",
				"useHookAtTopLevel": "off"
			},
			"performance": {
				"noImgElement": "off"
			},
			"style": {
				"noNonNullAssertion": "warn",
				"useConst": "error",
				"noDescendingSpecificity": "off"
			},
			"suspicious": {
				"noExplicitAny": "warn",
				"noTemplateCurlyInString": "off"
			}
		}
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"semicolons": "always"
		}
	},
	"files": {
		"includes": [
			"**",
			"!**/node_modules",
			"!**/dist",
			"!**/.next",
			"!**/coverage",
			"!**/reference",
			"!**/output",
			"!**/test-results",
			"!**/*.sql",
			"!**/*.sql.gz",
			"!**/.wrangler",
			"!**/packages/cli-rs/target",
			"!**/*.d.ts",
			"!**/*.tsbuildinfo",
			"!**/packages/**/*/src/**/*.js",
			"!**/packages/**/*/src/**/*.js.map",
			"!**/packages/**/*/src/**/*.d.ts"
		]
	},
	"overrides": [
		{
			"includes": [
				"**/src/components/ui/**",
				"**/apps/web/src/components/ui/**",
				"**/packages/ui/src/components/**"
			],
			"linter": {
				"rules": {
					"a11y": {
						"noLabelWithoutControl": "off",
						"useKeyWithClickEvents": "off",
						"useSemanticElements": "off"
					}
				}
			}
		},
		{
			"includes": [
				"**/src/components/forum/post-content.tsx",
				"**/apps/web/src/components/forum/post-content.tsx",
				"**/apps/admin/src/app/layout.tsx"
			],
			"linter": {
				"rules": {
					"security": {
						"noDangerouslySetInnerHtml": "off"
					}
				}
			}
		},
		{
			"includes": ["**/apps/web/src/components/**"],
			"linter": {
				"rules": {
					"a11y": {
						"noLabelWithoutControl": "off",
						"noSvgWithoutTitle": "off"
					}
				}
			}
		},
		{
			"includes": ["**/scripts/**"],
			"linter": {
				"rules": {
					"correctness": {
						"noUnusedVariables": "warn"
					},
					"suspicious": {
						"noAssignInExpressions": "off"
					}
				}
			}
		},
		{
			"includes": ["**/apps/admin/src/app/(admin)/admin/forums/page.tsx"],
			"linter": {
				"rules": {
					"suspicious": {
						"noArrayIndexKey": "off"
					}
				}
			}
		},
		{
			"includes": ["**/*.test.ts", "**/*.spec.ts", "**/tests/**"],
			"linter": {
				"rules": {
					"style": {
						"noUnusedTemplateLiteral": "off"
					},
					"suspicious": {
						"noExplicitAny": "off",
						"noFocusedTests": "error",
						"noSkippedTests": "error"
					}
				}
			}
		}
	]
}
