{
	"$schema": "https://biomejs.dev/schemas/1.9.0/schema.json",
	"organizeImports": {
		"enabled": true
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"complexity": {
				"noExcessiveCognitiveComplexity": {
					"level": "warn",
					"options": { "maxAllowedComplexity": 25 }
				}
			},
			"correctness": {
				"noUnusedVariables": "error",
				"noUnusedImports": "error"
			},
			"style": {
				"noNonNullAssertion": "warn",
				"useConst": "error"
			},
			"suspicious": {
				"noExplicitAny": "warn"
			}
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double",
			"semicolons": "always"
		}
	},
	"files": {
		"ignore": [
			"node_modules",
			"dist",
			".next",
			"reference",
			"*.sql",
			"*.sql.gz",
			".wrangler",
			"packages/cli-rs/target"
		]
	},
	"overrides": [
		{
			"include": [
				"src/components/ui/**",
				"apps/web/src/components/ui/**",
				"packages/ui/src/components/**"
			],
			"linter": {
				"rules": {
					"a11y": {
						"noLabelWithoutControl": "off",
						"useKeyWithClickEvents": "off",
						"useSemanticElements": "off"
					}
				}
			}
		},
		{
			"include": [
				"src/components/forum/post-content.tsx",
				"apps/web/src/components/forum/post-content.tsx",
				"apps/admin/src/app/layout.tsx"
			],
			"linter": {
				"rules": {
					"security": {
						"noDangerouslySetInnerHtml": "off"
					}
				}
			}
		},
		{
			"include": ["apps/web/src/components/**"],
			"linter": {
				"rules": {
					"a11y": {
						"noLabelWithoutControl": "off",
						"noSvgWithoutTitle": "off"
					}
				}
			}
		},
		{
			"include": ["scripts/**"],
			"linter": {
				"rules": {
					"correctness": {
						"noUnusedVariables": "warn"
					},
					"suspicious": {
						"noAssignInExpressions": "off"
					}
				}
			}
		},
		{
			"include": ["apps/admin/src/app/(admin)/admin/forums/page.tsx"],
			"linter": {
				"rules": {
					"suspicious": {
						"noArrayIndexKey": "off"
					}
				}
			}
		},
		{
			"include": ["**/*.test.ts", "**/*.spec.ts", "tests/**"],
			"linter": {
				"rules": {
					"style": {
						"noUnusedTemplateLiteral": "off"
					}
				}
			}
		}
	]
}
